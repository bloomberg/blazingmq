"""
Tweak generator.
"""

import dataclasses
from pathlib import Path
import subprocess
from typing import IO, Type, Union
import typing

from blazingmq.schemas import mqbcfg, mqbdomaincfg

from blazingmq.dev import it


def type_str(type_) -> str:
    if isinstance(type_, str):
        return type_

    if origin := typing.get_origin(type_):
        if origin == Union:
            nested = [type_str(item_type) for item_type in typing.get_args(type_)]
            return "Union[{}]".format(",".join(nested))
    else:
        return (
            type_.__qualname__
            if type_.__module__ == "builtins"
            else f"{type_.__module__}.{type_.__qualname__}"
        )


TWEAK_FORMAT = """
    def __call__(self, value: {type}) -> Callable: ...
{attr} = {class_name}()
"""


def print_indented(text: str, indent: int, file: IO[str]):
    for line in text.split("\n"):
        print(" " * 4 * indent, line, sep="", file=file)


def generate(cls: Type, indent: int, file: IO[str]):
    resolved_hints = typing.get_type_hints(cls)
    for field in dataclasses.fields(cls):
        field_type = resolved_hints[field.name]
        class_name = "".join([word.capitalize() for word in field.name.split("_")])

        print_indented(f"class {class_name}(metaclass=TweakMetaclass):", indent, file)

        if dataclasses.is_dataclass(field_type):
            generate(field_type, indent + 1, file)
        elif origin := typing.get_origin(field_type):
            if origin not in (typing.Union, list):
                assert False, f"add support for {origin}"

            nested_types = typing.get_args(field_type)
            for item_type in nested_types:
                if dataclasses.is_dataclass(item_type):
                    generate(item_type, indent + 1, file)

        print_indented(
            TWEAK_FORMAT.format(
                class_name=class_name,
                type=type_str(field_type),
                attr=field.name,
            ),
            indent,
            file,
        )


HEADER = r'''# Copyright 2026 Bloomberg Finance L.P.
# SPDX-License-Identifier: Apache-2.0
